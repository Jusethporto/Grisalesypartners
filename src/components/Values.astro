---
import { Icon } from "astro-icon/components";

const values = [
  { icon: "lucide:shield-check", title: "Integridad" },
  { icon: "lucide:award", title: "Excelencia" },
  { icon: "lucide:handshake", title: "Compromiso" },
  { icon: "lucide:lightbulb", title: "Innovación" },
  { icon: "lucide:compass", title: "Liderazgo Estratégico" },
  { icon: "lucide:eye", title: "Transparencia" },
];
---

<section id="nosotros" class="bg-surface py-24">
  <div class="mx-auto max-w-content px-6">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="font-body text-xs font-semibold uppercase tracking-widest text-gold">Lo que nos define</p>
      <h2 class="mt-3 font-heading text-3xl font-bold text-petrol sm:text-4xl">Nuestros Valores Fundacionales</h2>
    </div>

    <div class="reveal-stagger mt-16 grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-6">
      {
        values.map((value) => (
          <div class="group flex flex-col items-center gap-4 rounded-2xl border border-petrol/10 bg-surface-secondary/60 px-4 py-8 text-center transition-all duration-300 hover:-translate-y-1 hover:bg-surface hover:shadow-card">
            <span class="flex h-11 w-11 items-center justify-center rounded-full bg-white text-petrol shadow-subtle transition-colors duration-300 group-hover:text-gold">
              <Icon name={value.icon} class="h-5 w-5" />
            </span>
            <p class="font-body text-xs font-semibold uppercase tracking-wide text-petrol">{value.title}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
