---
import { Icon } from "astro-icon/components";

const quickLinks = [
  { href: "#servicios", label: "Servicios" },
  { href: "#metodologia", label: "Metodología" },
  { href: "#casos-de-exito", label: "Casos de Éxito" },
  { href: "#nosotros", label: "Sobre Nosotros" },
];

const legalLinks = [
  { href: "#", label: "Políticas de Privacidad" },
  { href: "#", label: "Términos de Servicio" },
  { href: "#", label: "Aviso Regulatorio" },
];

const year = new Date().getFullYear();
---

<footer class="bg-petrol-dark text-white">
  <div class="mx-auto grid max-w-content gap-12 px-6 py-16 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="flex items-center gap-2.5">
        <img src="/brand/icono-gp.svg" alt="" width="36" height="36" class="h-9 w-9 rounded-lg" />
        <span class="font-heading text-base font-bold">Grisales &amp; Partners</span>
      </div>
      <p class="mt-4 max-w-xs font-body text-sm text-white/60">
        Consultoría financiera de grado institucional. Transformamos la rentabilidad en activos de
        liquidez real.
      </p>
      <div class="mt-5 flex gap-3">
        <a
          href="#"
          aria-label="LinkedIn"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/15 text-white/70 transition-colors hover:border-gold hover:text-gold"
        >
          <Icon name="lucide:linkedin" class="h-4 w-4" />
        </a>
        <a
          href="#"
          aria-label="Twitter"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-white/15 text-white/70 transition-colors hover:border-gold hover:text-gold"
        >
          <Icon name="lucide:twitter" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div>
      <p class="font-body text-xs font-semibold uppercase tracking-widest text-gold">Menú Rápido</p>
      <ul class="mt-5 space-y-3">
        {
          quickLinks.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-white/70 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="font-body text-xs font-semibold uppercase tracking-widest text-gold">Legal</p>
      <ul class="mt-5 space-y-3">
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} class="font-body text-sm text-white/70 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="font-body text-xs font-semibold uppercase tracking-widest text-gold">Newsletter</p>
      <p class="mt-5 font-body text-sm text-white/70">Reciba insights estratégicos mensuales en su correo.</p>
      <form class="mt-4 flex overflow-hidden rounded-lg border border-white/15">
        <input
          type="email"
          placeholder="Email"
          aria-label="Correo para newsletter"
          class="w-full bg-transparent px-4 py-2.5 font-body text-sm text-white placeholder:text-white/40 focus:outline-none"
        />
        <button
          type="submit"
          aria-label="Suscribirse"
          class="flex items-center justify-center bg-gold px-4 text-petrol-dark transition-colors hover:bg-gold-light"
        >
          <Icon name="lucide:send" class="h-4 w-4" />
        </button>
      </form>
    </div>
  </div>

  <div class="border-t border-white/10 px-6 py-6">
    <div class="mx-auto flex max-w-content flex-col gap-2 font-body text-xs uppercase tracking-widest text-white/40 sm:flex-row sm:justify-between">
      <p>© {year} Grisales &amp; Partners. Institutional Grade Financial Consulting.</p>
      <p>Desarrollado para la excelencia financiera.</p>
    </div>
  </div>
</footer>
