---
import { Icon } from "astro-icon/components";
---

<section class="relative overflow-hidden bg-petrol py-24">
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-gold/10 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="reveal relative mx-auto max-w-3xl px-6 text-center">
    <h2 class="text-balance font-heading text-3xl font-bold leading-tight text-white sm:text-4xl">
      Convirtamos la rentabilidad de tu empresa en liquidez real.
    </h2>
    <a
      href="#contacto"
      class="mt-9 inline-flex animate-glow-pulse items-center gap-2 rounded-full bg-gold px-8 py-4 font-heading text-sm font-semibold text-petrol-dark transition-transform hover:scale-[1.03]"
    >
      Agenda una asesoría estratégica
      <Icon name="lucide:arrow-right" class="h-4 w-4" />
    </a>
  </div>
</section>
