---
import { Icon } from "astro-icon/components";
---

<section id="inicio" class="relative overflow-hidden bg-surface pb-24 pt-36 sm:pt-40">
  <div
    class="pointer-events-none absolute -right-40 -top-20 h-[32rem] w-[32rem] rounded-full bg-gold/10 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute left-0 top-1/3 h-64 w-64 -translate-x-1/2 rounded-full bg-petrol/5 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto grid max-w-content items-center gap-16 px-6 lg:grid-cols-2 lg:gap-12">
    <div class="reveal max-w-xl">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-gold/30 bg-gold/10 px-4 py-1.5 font-body text-xs font-semibold uppercase tracking-widest text-petrol"
      >
        <Icon name="lucide:shield-check" class="h-3.5 w-3.5 text-gold" />
        Firma Boutique de Consultoría Financiera
      </span>

      <h1 class="mt-6 text-balance font-heading text-4xl font-bold leading-[1.1] text-petrol sm:text-5xl lg:text-[3.4rem]">
        Transformamos <span class="text-gold">utilidades</span> en liquidez.
      </h1>

      <p class="mt-6 max-w-lg font-body text-lg leading-relaxed text-ink-secondary">
        Ayudamos a las empresas a convertir su rentabilidad en crecimiento sostenible mediante
        estrategias financieras inteligentes, optimización del capital de trabajo y gestión
        eficiente de liquidez.
      </p>

      <div class="mt-9 flex flex-col gap-3.5 sm:flex-row">
        <a
          href="#contacto"
          class="inline-flex items-center justify-center gap-2 rounded-full bg-gold px-7 py-3.5 font-heading text-sm font-semibold text-petrol-dark shadow-subtle transition-all hover:scale-[1.02] hover:shadow-gold"
        >
          Agenda una asesoría
          <Icon name="lucide:arrow-right" class="h-4 w-4" />
        </a>
        <a
          href="#servicios"
          class="inline-flex items-center justify-center rounded-full border border-petrol/15 px-7 py-3.5 font-heading text-sm font-semibold text-petrol transition-colors hover:bg-surface-secondary"
        >
          Conoce nuestros servicios
        </a>
      </div>
    </div>

    <div class="reveal relative" style="transition-delay:120ms">
      <div
        class="relative overflow-hidden rounded-3xl border border-petrol/10 bg-gradient-to-br from-petrol to-petrol-dark p-8 shadow-card sm:p-10"
      >
        <div class="flex items-center justify-between font-body text-xs uppercase tracking-widest text-white/50">
          <span>Panel de Liquidez</span>
          <span class="flex items-center gap-1.5 text-gold">
            <span class="h-1.5 w-1.5 rounded-full bg-gold animate-glow-pulse"></span>
            En vivo
          </span>
        </div>

        <div class="mt-8 flex items-end gap-6">
          <div>
            <p class="font-body text-xs uppercase tracking-widest text-white/50">Liquidez Proyectada</p>
            <p class="font-heading text-4xl font-bold text-white">$4.2M</p>
          </div>
          <span class="mb-1 flex items-center gap-1 font-body text-sm font-semibold text-gold-light">
            <Icon name="lucide:trending-up" class="h-4 w-4" />
            +24.8%
          </span>
        </div>

        <svg viewBox="0 0 320 120" class="mt-6 h-28 w-full" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="chart-fill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#C7A968" stop-opacity="0.35" />
              <stop offset="100%" stop-color="#C7A968" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path
            d="M0 95 C 40 90, 60 70, 90 68 C 130 65, 150 40, 190 38 C 230 36, 250 15, 320 10 L320 120 L0 120 Z"
            fill="url(#chart-fill)"
          />
          <path
            d="M0 95 C 40 90, 60 70, 90 68 C 130 65, 150 40, 190 38 C 230 36, 250 15, 320 10"
            fill="none"
            stroke="#C7A968"
            stroke-width="2.5"
            stroke-linecap="round"
            pathLength="1"
            class="animate-[draw-line_1.8s_ease-out_forwards]"
            style="stroke-dasharray:1;stroke-dashoffset:1"
          />
        </svg>

        <div class="mt-6 grid grid-cols-3 gap-4 border-t border-white/10 pt-6">
          <div>
            <p class="font-body text-[0.65rem] uppercase tracking-widest text-white/40">Flujo de Caja</p>
            <p class="font-heading text-lg font-semibold text-white">+18%</p>
          </div>
          <div>
            <p class="font-body text-[0.65rem] uppercase tracking-widest text-white/40">Ciclo de Cobro</p>
            <p class="font-heading text-lg font-semibold text-white">-32%</p>
          </div>
          <div>
            <p class="font-body text-[0.65rem] uppercase tracking-widest text-white/40">Margen EBITDA</p>
            <p class="font-heading text-lg font-semibold text-white">+11pp</p>
          </div>
        </div>
      </div>

      <div
        class="absolute -bottom-6 -left-6 hidden items-center gap-3 rounded-2xl border border-petrol/10 bg-surface px-5 py-4 shadow-card sm:flex"
      >
        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-gold/15 text-gold">
          <Icon name="lucide:trending-up" class="h-5 w-5" />
        </span>
        <div>
          <p class="font-body text-[0.65rem] uppercase tracking-widest text-ink-secondary">Crecimiento Anual</p>
          <p class="font-heading text-base font-bold text-petrol">+24.8%</p>
        </div>
      </div>
    </div>
  </div>
</section>
