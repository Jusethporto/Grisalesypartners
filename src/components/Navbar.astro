---
import { Icon } from "astro-icon/components";

const links = [
  { href: "#inicio", label: "Inicio" },
  { href: "#servicios", label: "Servicios" },
  { href: "#metodologia", label: "Metodología" },
  { href: "#casos-de-exito", label: "Casos de Éxito" },
  { href: "#nosotros", label: "Nosotros" },
  { href: "#contacto", label: "Contacto" },
];
---

<header
  data-navbar
  class="fixed inset-x-0 top-0 z-50 h-20 border-b border-petrol/5 bg-surface/40 backdrop-blur-lg transition-colors duration-300"
>
  <nav class="mx-auto flex h-full max-w-content items-center justify-between px-6">
    <a href="#inicio" class="flex items-center gap-2.5">
      <img src="/brand/icono-gp.svg" alt="" width="36" height="36" class="h-9 w-9 rounded-lg" />
      <span class="font-heading text-lg font-bold tracking-tight text-petrol">Grisales &amp; Partners</span>
    </a>

    <ul class="hidden items-center gap-8 lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body text-sm font-medium text-ink-secondary transition-colors hover:text-petrol"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="#contacto"
        class="hidden rounded-full bg-gold px-5 py-2.5 font-heading text-sm font-semibold text-petrol-dark shadow-subtle transition-transform hover:scale-[1.03] hover:shadow-gold sm:inline-block"
      >
        Agenda una asesoría
      </a>
      <button
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-label="Abrir menú de navegación"
        class="flex h-10 w-10 items-center justify-center rounded-full text-petrol lg:hidden"
      >
        <Icon name="lucide:menu" class="h-6 w-6" />
      </button>
    </div>
  </nav>

  <div
    data-nav-panel
    class="hidden flex-col gap-1 border-t border-petrol/5 bg-surface px-6 py-4 lg:hidden"
  >
    {
      links.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-2.5 font-body text-sm font-medium text-ink-secondary hover:bg-surface-secondary hover:text-petrol"
        >
          {link.label}
        </a>
      ))
    }
    <a
      href="#contacto"
      class="mt-2 rounded-full bg-gold px-5 py-2.5 text-center font-heading text-sm font-semibold text-petrol-dark"
    >
      Agenda una asesoría
    </a>
  </div>
</header>

<script src="../scripts/nav.ts"></script>
