---
const links = [
  { href: "#inicio", label: "Inicio" },
  { href: "#servicios", label: "Servicios" },
  { href: "#metodologia", label: "Metodología" },
  { href: "#casos-de-exito", label: "Casos de Éxito" },
  { href: "#nosotros", label: "Nosotros" },
  { href: "#contacto", label: "Contacto" },
];
---

<header
  data-navbar
  class="fixed inset-x-0 top-0 z-50 h-20 border-b border-petrol/5 bg-surface/40 backdrop-blur-lg transition-colors duration-300"
>
  <nav class="mx-auto flex h-full max-w-content items-center justify-between px-6">
    <a href="#inicio" class="flex items-center gap-2.5">
      <img src="/brand/icono-gp.svg" alt="" width="36" height="36" class="h-9 w-9 rounded-lg" />
      <span class="font-heading text-lg font-bold tracking-tight text-petrol">Grisales &amp; Partners</span>
    </a>

    <ul class="hidden items-center gap-8 lg:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="font-body text-sm font-medium text-ink-secondary transition-colors hover:text-petrol"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href="#contacto"
        class="hidden rounded-full bg-gold px-5 py-2.5 font-heading text-sm font-semibold text-petrol-dark shadow-subtle transition-transform hover:scale-[1.03] hover:shadow-gold sm:inline-block"
      >
        Agenda una asesoría
      </a>
      <button
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-label="Abrir menú de navegación"
        class="hamburger relative flex h-10 w-10 items-center justify-center rounded-full text-petrol lg:hidden"
      >
        <span class="sr-only">Menú</span>
        <span class="hamburger-line hamburger-line--top" aria-hidden="true"></span>
        <span class="hamburger-line hamburger-line--middle" aria-hidden="true"></span>
        <span class="hamburger-line hamburger-line--bottom" aria-hidden="true"></span>
      </button>
    </div>
  </nav>

  <div data-nav-panel-wrapper class="nav-panel-wrapper grid lg:hidden">
    <div class="nav-panel-inner overflow-hidden">
      <div
        data-nav-panel
        class="nav-stagger flex flex-col gap-1 border-t border-petrol/5 bg-surface px-6 py-4"
      >
        {
          links.map((link) => (
            <a
              href={link.href}
              class="rounded-lg px-3 py-2.5 font-body text-sm font-medium text-ink-secondary hover:bg-surface-secondary hover:text-petrol"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="#contacto"
          class="mt-2 rounded-full bg-gold px-5 py-2.5 text-center font-heading text-sm font-semibold text-petrol-dark"
        >
          Agenda una asesoría
        </a>
      </div>
    </div>
  </div>
</header>

<script src="../scripts/nav.ts"></script>

<style>
  .hamburger-line {
    position: absolute;
    width: 20px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform 0.35s cubic-bezier(0.65, 0, 0.35, 1),
      opacity 0.2s ease;
  }

  .hamburger-line--top {
    transform: translateY(-7px);
  }

  .hamburger-line--bottom {
    transform: translateY(7px);
  }

  .hamburger[aria-expanded="true"] .hamburger-line--top {
    transform: translateY(0) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line--bottom {
    transform: translateY(0) rotate(-45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line--middle {
    opacity: 0;
    transform: scale(0.5);
  }

  .nav-panel-wrapper {
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .nav-panel-wrapper[data-open="true"] {
    grid-template-rows: 1fr;
  }

  .nav-stagger > * {
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 0.3s ease,
      transform 0.3s cubic-bezier(0.65, 0, 0.35, 1);
    transition-delay: 0ms;
  }

  .nav-panel-wrapper[data-open="true"] .nav-stagger > * {
    opacity: 1;
    transform: translateY(0);
  }

  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(1) { transition-delay: 40ms; }
  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(2) { transition-delay: 80ms; }
  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(3) { transition-delay: 120ms; }
  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(4) { transition-delay: 160ms; }
  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(5) { transition-delay: 200ms; }
  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(6) { transition-delay: 240ms; }
  .nav-panel-wrapper[data-open="true"] .nav-stagger > *:nth-child(7) { transition-delay: 280ms; }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-line,
    .nav-panel-wrapper,
    .nav-stagger > * {
      transition: none !important;
    }
  }
</style>
