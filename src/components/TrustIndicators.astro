---
const stats = [
  { value: 150, prefix: "+", suffix: "", label: "Empresas asesoradas" },
  { value: 500, prefix: "$", suffix: "M+", label: "Capital optimizado" },
  { value: 35, prefix: "+", suffix: "%", label: "Incremento de liquidez" },
  { value: 12, prefix: "+", suffix: "", label: "Años de experiencia" },
];
---

<section class="bg-petrol">
  <div class="reveal-stagger mx-auto grid max-w-content grid-cols-2 gap-8 px-6 py-14 sm:grid-cols-4 sm:gap-6">
    {
      stats.map((stat) => (
        <div class="text-center">
          <p
            class="font-heading text-3xl font-bold text-white sm:text-4xl"
            data-count-to={stat.value}
            data-prefix={stat.prefix}
            data-suffix={stat.suffix}
          >
            {stat.prefix}0{stat.suffix}
          </p>
          <p class="mt-2 font-body text-xs uppercase tracking-widest text-white/60">{stat.label}</p>
        </div>
      ))
    }
  </div>
</section>

<script src="../scripts/counters.ts"></script>
